# 네이버 검색 API (https://developers.naver.com/apps 에서 발급)
NAVER_CLIENT_ID=여기에_클라이언트_ID
NAVER_CLIENT_SECRET=여기에_클라이언트_시크릿

# DART API — 업종 정보 수집용 (https://opendart.fss.or.kr/api/intro.do 에서 발급, 무료)
DART_API_KEY=여기에_DART_API_키

# 수집 설정
MAX_PAGES=6           # 법원 공고 최근 N개월치 엑셀 수집
SCHEDULE_HOUR=9       # 매일 실행 시각 (24시간제, KST 기준)
SCHEDULE_MINUTE=0
MAX_NAVER_QUERIES=50  # 1회 실행당 네이버 업종 개별 조회 최대 건수
